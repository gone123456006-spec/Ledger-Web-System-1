# Backend Configuration Template

# Environment
NODE_ENV=development
PORT=5000

# MongoDB connection
# Local:
MONGO_URI=mongodb://localhost:27017/ledger-db

# OR MongoDB Atlas (cloud):
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/ledger-db?retryWrites=true&w=majority

# JWT (change these for production!)
JWT_SECRET=super_secret_key_change_me_in_production_1234567890
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# CORS allowed origin (must match your frontend URL)
CORS_ORIGIN=http://localhost:8000

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Optional: default admin created by `npm run seed:default-user`
# Login page may show "Username"; if there is no @, app sends id + @ledger.co
# DEFAULT_LOGIN_EMAIL=u9xQ7mL2vT8kR4pZ@ledger.co
# DEFAULT_LOGIN_PASSWORD=your_strong_password_here

# Optional: Add more config as needed
LOG_LEVEL=debug
