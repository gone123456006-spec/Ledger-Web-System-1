{
  "framework": null,
  "buildCommand": null,
  "installCommand": null,
  "outputDirectory": ".",
  "cleanUrls": false,
  "trailingSlash": false,
  "redirects": [
    { "source": "/", "destination": "/frontend/index.html", "permanent": false },
    { "source": "/index.html", "destination": "/frontend/index.html", "permanent": false }
  ],
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "https://ledger-api-qmtc.onrender.com/api/v1/:path*"
    },
    { "source": "/login.html", "destination": "/frontend/login.html" },
    { "source": "/api-config.js", "destination": "/frontend/api-config.js" },
    { "source": "/sync-manager.js", "destination": "/frontend/sync-manager.js" },
    { "source": "/uptime-ping.js", "destination": "/frontend/uptime-ping.js" },
    { "source": "/style.css", "destination": "/frontend/style.css" },
    { "source": "/script.js", "destination": "/frontend/script.js" },
    { "source": "/auth.js", "destination": "/frontend/auth.js" },
    { "source": "/pages/:path*", "destination": "/frontend/pages/:path*" },
    { "source": "/script/:path*", "destination": "/frontend/script/:path*" },
    { "source": "/js/:path*", "destination": "/frontend/js/:path*" },
    { "source": "/assets/:path*", "destination": "/frontend/assets/:path*" }
  ],
  "headers": [
    {
      "source": "/frontend/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    },
    {
      "source": "/frontend/(.*)\\.(js|css)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, max-age=0, must-revalidate" }
      ]
    }
  ]
}
