{
  "cleanUrls": false,
  "trailingSlash": false,

  "rewrites": [
    {
      "source": "/",
      "destination": "/frontend/index.html"
    },
    {
      "source": "/index.html",
      "destination": "/frontend/index.html"
    },
    {
      "source": "/login.html",
      "destination": "/frontend/login.html"
    },

    {
      "source": "/pages/:path*",
      "destination": "/frontend/pages/:path*"
    },
    {
      "source": "/script/:path*",
      "destination": "/frontend/script/:path*"
    },
    {
      "source": "/js/:path*",
      "destination": "/frontend/js/:path*"
    },

    {
      "source": "/:path*.html",
      "destination": "/frontend/:path*.html"
    },
    {
      "source": "/:path*.js",
      "destination": "/frontend/:path*.js"
    },
    {
      "source": "/:path*.css",
      "destination": "/frontend/:path*.css"
    },

    {
      "source": "/:path*.(png|jpg|jpeg|gif|svg|ico|webp|woff|woff2|ttf|eot|otf|map|json)",
      "destination": "/frontend/:path*.$1"
    }
  ],

  "headers": [
    {
      "source": "/:path*.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    },

    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },

    {
      "source": "/:path*.{js,css}",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}